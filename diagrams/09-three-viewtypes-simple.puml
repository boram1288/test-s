@startuml
title 같은 온라인 서점을 세 관점으로 보기
left to right direction

package "모듈 View" #DDEBFF {
  [Order Module] as M1
  [Payment Adapter] as M2
  M1 ..> M2 : uses
}

package "C&C View" #E2F4DF {
  [Order Service] as C1
  [Payment Gateway] as C2
  C1 --> C2 : HTTPS 호출
}

package "배포 View" #FFF0D6 {
  node "Container Node" as N1 {
    artifact "order-service" as A1
  }
}

M1 ..> C1 : 구현됨
C1 ..> A1 : 패키징됨
@enduml
